    function fileToBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result);
            reader.onerror = error => reject(error);
            reader.readAsDataURL(file);
        });
    }

    function handleLyricsUpload(event) {
        const files = event.target.files;
        if (!files || files.length === 0) return;
        const statusEl = document.getElementById('lyrics-upload-status');
        if(statusEl) statusEl.textContent = `Memproses ${files.length} file lirik...`;

        let loadedCount = 0;
        Array.from(files).forEach(file => {
            const reader = new FileReader();
            const songTitle = file.name.replace(/\.[^/.]+$/, ""); 
            
            reader.onload = function(e) {
                const lyrics = e.target.result;
                songBank[songTitle] = lyrics;
                loadedCount++;
                
                if (firebaseActive) {
                    uploadSongToCloud(songTitle, lyrics);
                }

                if (loadedCount === files.length) {
                    localStorage.setItem('songBank', JSON.stringify(songBank));
                    renderSongList();
                    if(statusEl) statusEl.innerHTML = `<span class="text-green-400 font-medium flex items-center gap-1"><i data-lucide="check" class="w-3.5 h-3.5"></i> Sukses Memuat ${loadedCount} Lagu!</span>`;
                    showToast("Impor Lagu Berhasil", `${loadedCount} lagu telah dimuat ke Bank Lagu.`, "success");
                    if (window.lucide) {
                        lucide.createIcons();
                    }
                }
            };
            reader.readAsText(file);
        });
    }

    function handleBgUpload(event) {
        const file = event.target.files[0];
        if (!file) return;
        const statusEl = document.getElementById('bg-upload-status');
        if(statusEl) statusEl.textContent = "Membaca file media...";

        const reader = new FileReader();
        reader.onload = function(e) {
            const dataUrl = e.target.result;
            const isVideo = file.type.startsWith('video/');
            const bgType = isVideo ? 'video' : 'image';
            
            applyBg(bgType, dataUrl);
            if(statusEl) statusEl.innerHTML = `<span class="text-green-400 font-medium flex items-center gap-1"><i data-lucide="check" class="w-3.5 h-3.5"></i> Live Background (${bgType}) Diterapkan!</span>`;
            showToast("Latar Belakang Diubah", "Latar belakang langsung berhasil diterapkan pada visual jemaat.", "success");
            if (window.lucide) {
                lucide.createIcons();
            }
        };
        reader.readAsDataURL(file);
    }

    function loadBibleFromIndexedDB() {
