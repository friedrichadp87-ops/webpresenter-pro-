    function loadSongToQueue(title) {
        actionStates.clear = false;
        updateActionButtonsUI();
        currentMode = 'song';
        const rawLyrics = songBank[title] || '';
        const blocks = rawLyrics.split(/\n\s*\n/).map(b => b.trim()).filter(b => b.length > 0);
        
        if (blocks.length === 0) {
            activeSlides = [{ header: `${title} (Kosong)`, text: `(Lirik lagu kosong atau belum diisi)` }];
        } else {
            activeSlides = blocks.map((block, idx) => ({ header: `${title} (Bait ${idx+1})`, text: block }));
        }
        activeSlideIndex = 0;
        document.getElementById('active-content-title').innerHTML = `<span class="w-2 h-2 rounded-full bg-emerald-500"></span> Musik: ${title}`;
        document.getElementById('active-content-subtitle').textContent = `Berhasil menyusun lirik ke dalam rangkaian slide presentasi.`;
        renderQueue();
        selectSlide(0);
    }

