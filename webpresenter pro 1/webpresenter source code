    function saveSong() {
        const oldTitle = document.getElementById('edit-old-title').value.trim();
        const newTitle = document.getElementById('modal-song-title').value.trim();
        const lyrics = document.getElementById('modal-song-lyrics').value;
        if(!newTitle) {
            showToast("Kesalahan", "Judul lagu wajib diisi!", "error");
            return;
        }
        if(oldTitle && oldTitle !== newTitle) {
            delete songBank[oldTitle];
        }
        songBank[newTitle] = lyrics;
        localStorage.setItem('songBank', JSON.stringify(songBank));
        
        if (firebaseActive) {
            uploadSongToCloud(newTitle, lyrics);
        }

        closeSongModal();
        renderSongList();
        showToast("Tersimpan", `Lagu "${newTitle}" berhasil disimpan ke bank data.`, "success");
        if(currentMode === 'song' && (oldTitle === newTitle || !oldTitle)) {
            loadSongToQueue(newTitle);
        }
    }

    async function deleteSong(title) {
        if(await customConfirm("Hapus Lagu", `Apakah Anda yakin ingin menghapus lagu "${title}" dari bank data lokal?`)) {
            delete songBank[title];
            localStorage.setItem('songBank', JSON.stringify(songBank));
            
            if (firebaseActive) {
                firebase.database().ref('global_songs/' + title).remove();
            }

            const pIdx = songPlaylist.indexOf(title);
            if(pIdx !== -1) songPlaylist.splice(pIdx, 1);
            localStorage.setItem('songPlaylist', JSON.stringify(songPlaylist));
            renderSongList();
            renderPlaylist();
            showToast("Lagu Dihapus", `Lagu "${title}" telah dihapus secara permanen.`, "warning");
        }
    }

    function renderQueue() {
        const container = document.getElementById('slides-queue-container');
        container.innerHTML = '';
        if(activeSlides.length === 0) {
            container.innerHTML = `
                <div class="h-full flex flex-col items-center justify-center text-center p-6 text-gray-500 italic text-xs">
                    <i data-lucide="layers" class="w-8 h-8 mb-2 text-gray-600"></i> Tidak ada antrean slide aktif. Pilih Alkitab atau Lagu di kiri.
                </div>`;
            if (window.lucide) {
                lucide.createIcons();
            }
            return;
        }
        activeSlides.forEach((slide, idx) => {
            const block = document.createElement('div');
            block.id = `queue-slide-${idx}`;
            const isActive = idx === activeSlideIndex;
            block.className = `p-3 rounded-lg border text-left transition cursor-pointer slide-item group ${isActive ? 'bg-sky-950/60 border-sky-600 shadow-lg shadow-sky-950/40' : 'bg-gray-900/60 border-gray-800 hover:border-gray-700'}`;
            block.innerHTML = `
                <div class="flex items-center justify-between mb-1">
                    <span class="text-[10px] uppercase font-mono tracking-wider ${isActive ? 'text-sky-400' : 'text-gray-500 group-hover:text-gray-400'}">${slide.header}</span>
                    <span class="text-[10px] font-mono text-gray-600">Slide ${idx+1}</span>
                </div>
                <p class="text-xs ${isActive ? 'text-white font-semibold' : 'text-gray-300'} whitespace-pre-wrap leading-relaxed">${slide.text}</p>`;
            block.onclick = () => selectSlide(idx);
            container.appendChild(block);
        });
    }

    function selectSlide(index) {
        turnOffCamera(); 
        
        actionStates.clear = false;
        updateActionButtonsUI();
        if(index < 0 || index >= activeSlides.length) return;
        const prevIdx = activeSlideIndex;
        activeSlideIndex = index;
        
        const prevEl = document.getElementById(`queue-slide-${prevIdx}`);
        if(prevEl) {
            prevEl.className = 'p-3 rounded-lg border text-left transition cursor-pointer slide-item group bg-gray-900/60 border-gray-800 hover:border-gray-700';
            const span = prevEl.querySelector('span');
            if(span) span.className = 'text-[10px] uppercase font-mono tracking-wider text-gray-500 group-hover:text-gray-400';
            const p = prevEl.querySelector('p');
            if(p) p.className = 'text-xs text-gray-300';
        }
        const currEl = document.getElementById(`queue-slide-${index}`);
        if(currEl) {
            currEl.className = 'p-3 rounded-lg border text-left transition cursor-pointer slide-item group bg-sky-950/60 border-sky-600 shadow-lg shadow-sky-950/40';
            const span = currEl.querySelector('span');
            if(span) span.className = 'text-[10px] uppercase font-mono tracking-wider text-sky-400';
            const p = currEl.querySelector('p');
            if(p) p.className = 'text-xs text-white font-semibold';
            currEl.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
        
        const monJemaatImg = document.getElementById('monitor-jemaat-img');
        if (monJemaatImg) monJemaatImg.classList.add('hidden');
        
        updateOperatorPreviews();
        broadcastState();
    }

