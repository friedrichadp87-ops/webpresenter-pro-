    function applyLiveBackgroundStyles(element, bgObj) {
        if(!element || !bgObj) return;
        
        const oldVideo = element.querySelector('.bg-video-loop');
        if(oldVideo) {
            if(oldVideo.srcObject) {
                const tracks = oldVideo.srcObject.getTracks();
                tracks.forEach(t => t.stop());
            }
            oldVideo.remove();
        }

        if (bgObj.type === 'color') {
            element.style.backgroundImage = 'none';
            element.style.backgroundColor = bgObj.value;
        } else if (bgObj.type === 'gradient') {
            element.style.backgroundImage = bgObj.value;
        } else if (bgObj.type === 'image') {
            element.style.backgroundImage = `url('${bgObj.value}')`;
            element.style.backgroundSize = 'cover';
            element.style.backgroundPosition = 'center';
        } else if (bgObj.type === 'video' || bgObj.type === 'camera') {
            element.style.backgroundImage = 'none';
            element.style.backgroundColor = '#000000';
            
            const video = document.createElement('video');
            video.className = 'bg-video-loop absolute inset-0 w-full h-full object-cover pointer-events-none';
            video.style.zIndex = '0';
            video.autoplay = true;
            if (bgObj.type === 'video') video.loop = true;
            video.muted = true;
            video.playsInline = true;
            
            if(element.id === 'monitor-stage-bg' || element.id === 'stage-view') {
                video.style.opacity = '0.35'; 
            }

            if (element.style.position !== 'absolute' && element.style.position !== 'relative') {
                element.style.position = 'relative';
            }
            
            Array.from(element.children).forEach(child => {
                if(child !== video) {
                    child.style.position = 'relative';
                    child.style.zIndex = '10';
                }
            });
            element.appendChild(video);

            if (bgObj.type === 'video') {
                video.src = bgObj.value;
                video.play().catch(err => console.log("Autoplay ditangguhkan browser:", err));
            } else if (bgObj.type === 'camera') {
                navigator.mediaDevices.getUserMedia({ video: true })
                    .then(stream => {
                        video.srcObject = stream;
                        video.play().catch(err => console.log("Kamera autoplay ditangguhkan:", err));
                    })
                    .catch(err => {
                        console.error("Akses kamera ditolak atau tidak ditemukan:", err);
                    });
            }
        }
    }

