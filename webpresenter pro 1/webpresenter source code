    let sermonDb;
    let sermonSlidesArray = [];
    let currentSermonIndex = -1;

    function initSermonDB() {
        let request = indexedDB.open("SermonPresenterDB", 1);
        request.onupgradeneeded = (e) => {
            let db = e.target.result;
            if (!db.objectStoreNames.contains("sermon_slides")) {
                db.createObjectStore("sermon_slides", { keyPath: "id", autoIncrement: true });
            }
        };
        request.onsuccess = (e) => {
            sermonDb = e.target.result;
            loadSermonSlides();
        };
    }

    function loadSermonSlides() {
        if (!sermonDb) return;
        let transaction = sermonDb.transaction("sermon_slides", "readonly");
        let store = transaction.objectStore("sermon_slides");
        let request = store.getAll();
        request.onsuccess = () => {
            sermonSlidesArray = request.result || [];
            renderSermonList();
        };
    }

    function saveSermonSlide(slideObj) {
        return new Promise((resolve) => {
            let transaction = sermonDb.transaction("sermon_slides", "readwrite");
            let store = transaction.objectStore("sermon_slides");
            let request = store.add(slideObj);
            request.onsuccess = () => resolve();
        });
    }

    async function clearSermonSlides() {
        if (await customConfirm("Hapus Slide", "Apakah Anda yakin ingin menghapus semua gambar slide khotbah? Memori browser akan dikosongkan.")) {
            let transaction = sermonDb.transaction("sermon_slides", "readwrite");
            let store = transaction.objectStore("sermon_slides");
            let request = store.clear();
            request.onsuccess = () => {
                sermonSlidesArray = [];
                currentSermonIndex = -1;
                if (currentMode === 'sermon') {
                    currentMode = '';
                    updateOperatorPreviews();
                    broadcastState();
                }
                renderSermonList();
                showToast("Dihapus", "Seluruh slide khotbah berhasil dikosongkan.", "success");
            };
        }
    }

    async function handleSermonUpload(event) {
        const files = Array.from(event.target.files);
        if (files.length === 0) return;

        files.sort((a, b) => a.name.localeCompare(b.name, undefined, { numeric: true, sensitivity: 'base' }));

        const badge = document.getElementById('sermon-counter-badge');
        if (badge) badge.textContent = "Memproses...";

        for (const file of files) {
            const base64Data = await fileToBase64(file);
            await saveSermonSlide({ name: file.name, data: base64Data });
        }

        event.target.value = ""; 
        loadSermonSlides();
        showToast("Unggah Berhasil", `${files.length} slide khotbah dimuat ke sistem.`, "success");
    }

    function renderSermonList() {
        const container = document.getElementById('sermon-list-container');
        const badge = document.getElementById('sermon-counter-badge');
        if (!container) return;

        container.innerHTML = '';
        if (badge) badge.textContent = `${sermonSlidesArray.length} Slide`;

        if (sermonSlidesArray.length === 0) {
            container.innerHTML = `
                <div id="sermon-empty-state" class="text-center py-8 text-gray-500 italic text-[11px] border border-dashed border-gray-800 rounded-lg p-4">
                  Belum ada slide. Silakan upload gambar slide khotbah (JPEG/PNG) yang diekspor dari PPT.
                </div>`;
            return;
        }

        sermonSlidesArray.forEach((slide, idx) => {
            const item = document.createElement('div');
            const isActive = (currentMode === 'sermon' && idx === currentSermonIndex);
            item.className = `p-2 bg-gray-800/40 border ${isActive ? 'border-blue-500 bg-blue-950/20' : 'border-gray-800'} hover:border-blue-500 rounded-lg cursor-pointer transition flex flex-col gap-1.5`;
            item.innerHTML = `
                <div class="aspect-[16/9] w-full bg-black rounded overflow-hidden shadow-inner">
                    <img src="${slide.data}" alt="${slide.name}" class="w-full h-full object-contain">
                </div>
                <div class="flex items-center justify-between px-1">
                    <span class="text-[10px] font-mono bg-gray-900 text-gray-400 px-1.5 py-0.5 rounded font-bold">${idx + 1}</span>
                    <span class="text-[10px] text-gray-400 truncate max-w-[150px] font-medium">${slide.name}</span>
                </div>
            `;
            item.onclick = () => selectSermonSlide(idx);
            container.appendChild(item);
        });
    }

    function selectSermonSlide(idx) {
        turnOffCamera();
        currentMode = 'sermon';
        currentSermonIndex = idx;
        
        const items = document.getElementById('sermon-list-container').children;
        Array.from(items).forEach((item, index) => {
            if (index === idx) {
                item.classList.add('border-blue-500', 'bg-blue-950/20');
                item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                item.classList.remove('border-blue-500', 'bg-blue-950/20');
            }
        });

        const queueItems = document.getElementById('slides-queue-container').children;
        Array.from(queueItems).forEach(item => {
            item.className = 'p-3 rounded-lg border text-left transition cursor-pointer slide-item group bg-gray-900/60 border-gray-800 hover:border-gray-700';
        });

        document.getElementById('active-content-title').innerHTML = `<span class="w-2 h-2 rounded-full bg-amber-500"></span> Khotbah PPT: ${sermonSlidesArray[idx].name}`;
        document.getElementById('active-content-subtitle').textContent = `Slide khotbah JPEG aktif saat ini. Kontrol navigasi dengan keyboard.`;

        updateOperatorPreviews();
        broadcastState();
    }

