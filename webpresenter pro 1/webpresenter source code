        broadcastState();
    }

    function switchTab(tabName) {
        const tabs = ['alkitab', 'lagu', 'khotbah', 'playlist', 'media', 'remote', 'pengaturan'];
        tabs.forEach(t => {
            const btn = document.getElementById(`btn-tab-${t}`);
            const panel = document.getElementById(`panel-${t}`);
            if(!btn || !panel) return;
            if(t === tabName) {
                if(t === 'pengaturan') btn.className = "w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-sky-400 bg-sky-950/50 border border-sky-800/50 mt-auto";
                else btn.className = "w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-sky-400 bg-sky-950/50 border border-sky-800/50";
                panel.classList.remove('hidden');
            } else {
                if(t === 'pengaturan') btn.className = "w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800 mt-auto";
                else btn.className = "w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800";
                panel.classList.add('hidden');
            }
        });
    }

    function updateOperatorPreviews() {
        const monJemaat = document.getElementById('monitor-jemaat');
        const monStageCurr = document.getElementById('monitor-stage-curr');
        const monStageNext = document.getElementById('monitor-stage-next');
        const currentSlide = activeSlides[activeSlideIndex] || null;
        const nextSlide = activeSlides[activeSlideIndex + 1] || null;
        
        const monJemaatImg = document.getElementById('monitor-jemaat-img');
        const monStageImg = document.getElementById('monitor-stage-img');
        if (monJemaatImg) monJemaatImg.classList.add('hidden');
        if (monStageImg) monStageImg.classList.add('hidden');

        if(monJemaat) {
            const monJemaatBg = document.getElementById('monitor-jemaat-bg');
            if (actionStates.black) {
                monJemaat.textContent = '';
                if(monJemaatBg) {
                    monJemaatBg.style.backgroundImage = 'none';
                    monJemaatBg.style.backgroundColor = '#000000';
                    const vid = monJemaatBg.querySelector('.bg-video-loop');
                    if(vid) vid.remove();
                }
            } else if (actionStates.logo) {
                monJemaat.textContent = currentChurchName;
                if(monJemaatBg) {
                    monJemaatBg.style.backgroundImage = 'none';
                    monJemaatBg.style.backgroundColor = '#111827';
                    const vid = monJemaatBg.querySelector('.bg-video-loop');
                    if(vid) vid.remove();
                }
            } else if (actionStates.clear) {
                monJemaat.textContent = '';
                if(monJemaatBg) applyLiveBackgroundStyles(monJemaatBg, configBg);
            } else {
                if (currentMode === 'sermon' && sermonSlidesArray[currentSermonIndex]) {
                    monJemaat.textContent = '';
                    if (monJemaatImg) {
                        monJemaatImg.src = sermonSlidesArray[currentSermonIndex].data;
                        monJemaatImg.classList.remove('hidden');
                    }
                } else {
                    monJemaat.textContent = currentSlide ? currentSlide.text : '';
                    if(monJemaatBg) applyLiveBackgroundStyles(monJemaatBg, configBg);
                }
            }
        }
        
        if(monStageCurr) {
            if (currentMode === 'sermon' && sermonSlidesArray[currentSermonIndex]) {
                monStageCurr.textContent = '';
                if (monStageImg) {
                    monStageImg.src = sermonSlidesArray[currentSermonIndex].data;
                    monStageImg.classList.remove('hidden');
                }
                if (monStageNext) {
                    const nextSermon = sermonSlidesArray[currentSermonIndex + 1];
                    monStageNext.textContent = nextSermon ? "SELANJUTNYA:\n" + nextSermon.name : 'SELANJUTNYA: (Selesai/Habis)';
                }
            } else {
                monStageCurr.textContent = currentSlide ? currentSlide.text : '';
                if(monStageNext) {
                    if (typeof configBg !== 'undefined' && configBg && configBg.type === 'camera') {
                        monStageNext.parentElement.classList.add('hidden');
                    } else {
                        monStageNext.parentElement.classList.remove('hidden');
                        monStageNext.textContent = nextSlide ? "SELANJUTNYA:\n" + nextSlide.text : 'SELANJUTNYA: (Selesai/Habis)';
                    }
                }
            }
        }
    }

    function broadcastState() {
        const currentSlide = activeSlides[activeSlideIndex] || null;
        const nextSlide = activeSlides[activeSlideIndex + 1] || null;
        
        const payload = {
            type: 'sync',
            states: actionStates,
            bg: configBg,
            fontJemaat: fontSizeJemaat,
            fontStage: fontSizeStage,
            churchName: currentChurchName,
            currentText: currentSlide ? currentSlide.text : '',
            nextText: nextSlide ? nextSlide.text : '',
            currentMode: currentMode,
            sermonImage: currentMode === 'sermon' && sermonSlidesArray[currentSermonIndex] ? sermonSlidesArray[currentSermonIndex].data : ''
        };
        
        if (localBroadcastChannel) {
            localBroadcastChannel.postMessage(payload);
        }

        if (firebaseActive && currentUser) {
            const cleanEmailPath = currentUser.email.replace(/[^a-zA-Z0-9]/g, "_");
            firebase.database().ref('rooms/' + cleanEmailPath + '/live_state').set(payload);
        }

        if (remoteConn && remoteConn.open) {
            remoteConn.send(payload);
        }
        if (peer) {
            for (let peerId in peer.connections) {
                peer.connections[peerId].forEach(c => {
                    if (c.open) c.send(payload);
                });
            }
        }
    }

    function initPeer() {
        peer = new Peer();
        peer.on('open', (id) => {
            myPeerId = id;
            const disp = document.getElementById('peer-id-display');
            if(disp) disp.textContent = id;
        });
        peer.on('connection', (connection) => {
            conn = connection;
            conn.on('open', () => {
                broadcastState();
            });
            conn.on('data', (data) => {
                if (data.type === 'command') {
                    if (data.action === 'nav') navigateSlide(data.direction);
                    else if (data.action === 'toggle') toggleAction(data.target);
                }
            });
        });
    }

    function connectToRemoteTarget() {
        const targetId = document.getElementById('remote-target-id').value.trim();
        if(!targetId) return;
        if(remoteConn) remoteConn.close();
        
        remoteConn = peer.connect(targetId);
        remoteConn.on('open', () => {
            const statusEl = document.getElementById('connection-status');
            if(statusEl) {
                statusEl.textContent = "Terhubung Remote";
                statusEl.parentElement.className = "flex items-center gap-2 text-xs bg-amber-950/40 px-3 py-1.5 rounded-md border border-amber-800";
                statusEl.className = "text-amber-400 font-medium";
            }
            showToast("Sukses Konek", "Remote pengontrol terhubung ke monitor master utama.", "success");
            
            window.addEventListener('keydown', (e) => {
                if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;
                if (e.key === 'ArrowDown' || e.key === ' ') {
                    remoteConn.send({ type: 'command', action: 'nav', direction: 'down' });
                } else if (e.key === 'ArrowUp') {
                    remoteConn.send({ type: 'command', action: 'nav', direction: 'up' });
                } else if (e.key.toLowerCase() === 'c') {
                    remoteConn.send({ type: 'command', action: 'toggle', target: 'clear' });
                } else if (e.key.toLowerCase() === 'b') {
                    remoteConn.send({ type: 'command', action: 'toggle', target: 'black' });
                } else if (e.key.toLowerCase() === 'l') {
                    remoteConn.send({ type: 'command', action: 'toggle', target: 'logo' });
                }
            });
        });
        remoteConn.on('close', () => {
            const statusEl = document.getElementById('connection-status');
            if(statusEl) {
                statusEl.textContent = "Lokal Aktif";
                statusEl.parentElement.className = "flex items-center gap-2 text-xs bg-gray-800 px-3 py-1.5 rounded-md border border-gray-700";
                statusEl.className = "text-gray-300 font-medium";
            }
            remoteConn = null;
        });
    }

    window.addEventListener('keydown', (e) => {
        if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
            return;
        }
        if (e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown') {
            e.preventDefault();
            navigateSlide('down');
        } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
            e.preventDefault();
            navigateSlide('up');
        } else if (e.key.toLowerCase() === 'c') {
            toggleAction('clear');
        } else if (e.key.toLowerCase() === 'b') {
            toggleAction('black');
        } else if (e.key.toLowerCase() === 'l') {
            toggleAction('logo');
        }
    });

    function navigateSlide(direction) {
        if (currentMode === 'sermon' && sermonSlidesArray.length > 0) {
            let nextIdx = currentSermonIndex;
            if (direction === 'down') {
                nextIdx = currentSermonIndex + 1;
            } else if (direction === 'up') {
                nextIdx = currentSermonIndex - 1;
            }
            if (nextIdx >= 0 && nextIdx < sermonSlidesArray.length) {
                selectSermonSlide(nextIdx);
            }
            return;
        }
        if(activeSlides.length === 0) return;
        if(direction === 'down') {
            if(activeSlideIndex < activeSlides.length - 1) {
                selectSlide(activeSlideIndex + 1);
            }
        } else if (direction === 'up') {
            if(activeSlideIndex > 0) {
                selectSlide(activeSlideIndex - 1);
            }
        }
    }

    function renderPresentationView(mode) {
        document.body.className = "h-full bg-black flex items-center justify-center overflow-hidden";
        
       if (mode === 'jemaat') {
            document.title = "LAYAR JEMAAT - WebPresenter Pro";
            document.body.innerHTML = `
                <div id="jemaat-wrapper" class="w-full h-full flex items-center justify-center text-center transition-all duration-200 relative overflow-hidden" style="background-color: #030712; padding: 4vw;">
                    <img id="jemaat-img" class="absolute inset-0 w-full h-full object-contain hidden" style="z-index: 15;">
                    <div id="jemaat-text" class="text-white font-bold whitespace-pre-wrap tracking-wide text-long-distance z-10" style="font-size: 7vh; line-height: 1.35;"></div>
                </div>`;
        } else if (mode === 'stage') {
            document.title = "STAGE DISPLAY - WebPresenter Pro";
            document.body.innerHTML = `
                <div id="stage-view" class="w-full h-full bg-black overflow-hidden flex flex-col relative">
                    <img id="stage-img" class="absolute inset-0 w-full h-full object-contain hidden" style="z-index: 15; opacity: 0.85;">
                    <div id="stage-curr-container" class="h-[68%] flex items-center justify-center p-8 border-b border-zinc-900 z-10 relative transition-all duration-300">
                        <div id="stage-curr" class="text-center font-bold text-yellow-400 w-full transition-opacity duration-150 select-none uppercase tracking-wide leading-tight drop-shadow-lg">
                        </div>
                    </div>

                    <div id="stage-next-container" class="h-[32%] flex items-center justify-center p-6 bg-blue-950/70 border-t border-blue-900/50 z-10 relative backdrop-blur-sm transition-all duration-300">
                        <div id="stage-next" class="text-center font-semibold text-white w-full transition-opacity duration-150 select-none normal-case tracking-wide leading-snug line-clamp-3 overflow-hidden drop-shadow-md">
                        </div>
                    </div>

                </div>`;
        
        } else if (mode === 'obs') {
            document.title = "OBS OVERLAY - WebPresenter Pro";
            document.body.className = "h-full bg-[#00ff00] overflow-hidden";
            document.body.innerHTML = `
                <div id="obs-wrapper" class="w-full h-full flex items-end justify-center text-center p-12 transition-all duration-200">
                    <img id="obs-img" class="absolute inset-0 w-full h-full object-contain hidden" style="z-index: 15;">
                    <div id="obs-text" class="text-white font-bold whitespace-pre-wrap tracking-wide bg-black/70 px-8 py-4 rounded-2xl border border-gray-800/40 opacity-0 transition-all duration-300 transform translate-y-4" style="font-size: 4.5vh; line-height: 1.4; max-width: 85%;"></div>
                </div>`;
        }

        window.processIncomingStateDirect = function(targetMode, data) {
            processIncomingState(data);
        }

        function processIncomingState(data) {
            if (!data) return;

            if (mode === 'jemaat' || mode === 'obs') {
                const txt = document.getElementById('jemaat-text') || document.getElementById('obs-text');
                const wrapper = document.getElementById('jemaat-wrapper') || document.getElementById('obs-wrapper');
                
                const imgEl = document.getElementById(mode === 'jemaat' ? 'jemaat-img' : 'obs-img');
                if (imgEl) imgEl.classList.add('hidden');

                if (txt && wrapper) {
                    if (mode === 'obs') {
                        txt.setAttribute('data-base-font', '4.2');
                    } else {
                        txt.setAttribute('data-base-font', data.fontJemaat || '7');
                    }

                    if (data.states.black) {
                        txt.textContent = '';
                        if (mode === 'jemaat') {
                            wrapper.style.backgroundImage = 'none';
                            wrapper.style.backgroundColor = '#000000';
                            const vid = wrapper.querySelector('.bg-video-loop');
                            if(vid) vid.remove();
                        } else {
                            txt.classList.add('opacity-0', 'translate-y-4');
                        }
                    } else if (data.states.logo) {
                        if (mode === 'jemaat') {
                            txt.textContent = data.churchName;
                            wrapper.style.backgroundImage = 'none';
                            wrapper.style.backgroundColor = '#111827';
                            const vid = wrapper.querySelector('.bg-video-loop');
                            if(vid) vid.remove();
                        } else {
                            txt.textContent = '';
                            txt.classList.add('opacity-0', 'translate-y-4');
                        }
                    } else if (data.states.clear) {
                        txt.textContent = '';
                        if (mode === 'jemaat') {
                            applyLiveBackgroundStyles(wrapper, data.bg);
                        } else {
                            txt.classList.add('opacity-0', 'translate-y-4');
                        }
                    } else {
                        if (data.currentMode === 'sermon' && data.sermonImage) {
                            txt.textContent = '';
                            if (imgEl) {
                                imgEl.src = data.sermonImage;
                                imgEl.classList.remove('hidden');
                            }
                            if (mode === 'obs') {
                                txt.classList.remove('opacity-0', 'translate-y-4');
                            }
                        } else {
                            txt.textContent = data.currentText;
                            
                            if (mode === 'jemaat') {
                                applyLiveBackgroundStyles(wrapper, data.bg);
                            } else if (mode === 'obs') {
                                wrapper.style.backgroundColor = '#00ff00'; 
                                wrapper.style.backgroundImage = 'none';
                                const vid = wrapper.querySelector('.bg-video-loop');
                                if(vid) vid.remove();

                                if(data.currentText) {
                                    txt.classList.remove('opacity-0', 'translate-y-4');
                                } else {
                                    txt.classList.add('opacity-0', 'translate-y-4');
                                }
                            }
                        }
                    }
                    autoFitText(); 
                }
            } else if (mode === 'stage') {
                const txtCurr = document.getElementById('stage-curr');
                const txtNext = document.getElementById('stage-next');
                const stageWrapper = document.getElementById('stage-view');
                
                const currContainer = document.getElementById('stage-curr-container');
                const nextContainer = document.getElementById('stage-next-container');
                const stageImg = document.getElementById('stage-img');

                if(!txtCurr || !txtNext || !stageWrapper) return;

                if (stageImg) stageImg.classList.add('hidden');

                txtCurr.setAttribute('data-base-font', data.fontStage || '12');
                txtNext.setAttribute('data-base-font', '5.5'); 

                if (data.currentMode === 'sermon' && data.sermonImage) {
                    txtCurr.textContent = '';
                    if (stageImg) {
                        stageImg.src = data.sermonImage;
                        stageImg.classList.remove('hidden');
                    }
                    if (nextContainer) nextContainer.classList.add('hidden');
                } else {
                    txtCurr.textContent = data.currentText;
                    if (nextContainer) nextContainer.classList.remove('hidden');

                    if (data.bg && data.bg.type === 'camera') {
                        nextContainer.classList.add('hidden');
                        nextContainer.classList.remove('flex');
                        
                        currContainer.classList.remove('h-[68%]', 'border-b');
                        currContainer.classList.add('h-full');
                        
                        txtNext.textContent = '';
                    } else {
                        nextContainer.classList.remove('hidden');
                        nextContainer.classList.add('flex');
                        
                        currContainer.classList.remove('h-full');
                        currContainer.classList.add('h-[68%]', 'border-b');
                        
                        txtNext.textContent = data.nextText ? "SELANJUTNYA:\n" + data.nextText : "SELANJUTNYA: (Selesai/Habis)";
                    }
                }

                applyLiveBackgroundStyles(stageWrapper, data.bg);
                autoFitText();
            }
        }

        if (typeof BroadcastChannel !== 'undefined') {
            const clientChan = new BroadcastChannel('webpresenter_pro_local_sync');
            clientChan.onmessage = (e) => {
                processIncomingState(e.data);
            };
        }

        const viewPeer = new Peer();
        viewPeer.on('open', (id) => {
            const masterId = window.opener ? window.opener.myPeerId : null;
            if (masterId) {
                const clientConn = viewPeer.connect(masterId);
                clientConn.on('data', (data) => {
                    processIncomingState(data);
                });
            }
        });

        setTimeout(() => {
            if (window.opener && window.opener.firebaseConfig) {
                firebaseConfig = window.opener.firebaseConfig;
                currentUser = window.opener.currentUser;
                initFirebase();
            }
        }, 800);
    }

    function autoFitText() {
        const ids = ['jemaat-text', 'stage-curr', 'stage-next', 'obs-text'];

        ids.forEach(id => {
            const txt = document.getElementById(id);
            if (!txt) return; 

            let baseFontAttr = txt.getAttribute('data-base-font');
            let maxFont = baseFontAttr ? parseFloat(baseFontAttr) : 10;
            let currentSize = maxFont;
            txt.style.fontSize = currentSize + 'vh';

            let parentHeight = txt.parentElement.clientHeight || window.innerHeight;
            let parentWidth = txt.parentElement.clientWidth || window.innerWidth;

            let targetHeight = parentHeight * 0.85; 
            let targetWidth = parentWidth * 0.92;   

            if (id === 'jemaat-text') {
                while (txt.scrollHeight > targetHeight && currentSize > 4) {
                    currentSize -= 0.1;
                    txt.style.fontSize = currentSize + 'vh';
                }
            } 
            else if (id === 'stage-curr' || id === 'stage-next') {
                let minFloor = (id === 'stage-curr') ? 5.5 : 3.8;
                while (txt.scrollHeight > targetHeight && currentSize > minFloor) {
                    currentSize -= 0.1;
                    txt.style.fontSize = currentSize + 'vh';
                }
            }
            else {
                while ((txt.scrollHeight > targetHeight || txt.scrollWidth > targetWidth) && currentSize > 2) {
                    currentSize -= 0.1;
                    txt.style.fontSize = currentSize + 'vh';
                }
            }
        });
    }
    window.addEventListener('resize', () => { autoFitText(); });
  </script>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
        const isRunningOnServer = window.location.protocol.startsWith('http');
        const obsContainer = document.getElementById('obs-link-container');
        const obsUrlInput = document.getElementById('obs-url-input');

        if (isRunningOnServer && obsContainer && obsUrlInput) {
            const currentUrl = window.location.origin + window.location.pathname + '?view=obs';
            obsUrlInput.value = currentUrl;
            
            obsContainer.classList.remove('hidden');
        }
    });

    function copyObsUrl() {
        const copyText = document.getElementById("obs-url-input");
        if (copyText) {
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            
            // Menggunakan browser document fallback untuk interoperabilitas iFrame
            document.execCommand('copy');
            
            const btnText = document.getElementById("obs-copy-text");
            if (btnText) {
                btnText.innerText = "Tersalin!";
                btnText.classList.add("text-green-400");
                setTimeout(() => {
                    btnText.innerText = "Salin";
                    btnText.classList.remove("text-green-400");
                }, 2000);
            }
        }
    }
  </script>
