    function handleAuthSubmit(e) {
        e.preventDefault();
        const email = document.getElementById('auth-email').value.trim();
        const password = document.getElementById('auth-password').value;
        const churchNameInput = document.getElementById('auth-church').value.trim();

        if (firebaseActive) {
            showAuthStatus("Menghubungkan ke Google Cloud...", "sky");
            if (authTab === 'login') {
                firebase.auth().signInWithEmailAndPassword(email, password)
                    .then((userCredential) => {
                        showAuthStatus("Berhasil Masuk!", "green");
                        setTimeout(() => {
                            document.getElementById('auth-screen').classList.add('hidden');
                        }, 1000);
                    })
                    .catch((error) => {
                        showAuthStatus("Gagal Masuk: " + error.message, "rose");
                    });
            } else {
                firebase.auth().createUserWithEmailAndPassword(email, password)
                    .then((userCredential) => {
                        const user = userCredential.user;
                        user.updateProfile({ displayName: churchNameInput || "Gereja Lokal" });
                        showAuthStatus("Pendaftaran Akun Sukses!", "green");
                        setTimeout(() => {
                            document.getElementById('auth-screen').classList.add('hidden');
                        }, 1000);
                    })
                    .catch((error) => {
                        showAuthStatus("Pendaftaran Gagal: " + error.message, "rose");
                    });
            }
        } else {
            showAuthStatus("Memproses Akun Lokal (Demo)...", "amber");
            setTimeout(() => {
                let simulatedUsers = JSON.parse(localStorage.getItem('simulatedUsers')) || {};
                
                if (authTab === 'login') {
                    if (simulatedUsers[email] && simulatedUsers[email].password === password) {
                        showAuthStatus("Berhasil Masuk (Mode Demo)!", "green");
                        currentUser = { email: email, displayName: simulatedUsers[email].church };
                        userLoggedIn = true;
                        localStorage.setItem('currentSimUser', JSON.stringify(currentUser));
                        setTimeout(() => {
                            bypassAuth();
                        }, 1000);
                    } else {
                        showAuthStatus("Gagal: Email atau Sandi salah (Buat akun baru atau klik Mode Offline)", "rose");
                    }
                } else {
                    simulatedUsers[email] = { password: password, church: churchNameInput || "Gereja Demo" };
                    localStorage.setItem('simulatedUsers', JSON.stringify(simulatedUsers));
                    showAuthStatus("Akun Demo Terdaftar! Silakan klik tab Masuk.", "green");
                }
            }, 800);
        }
    }

    function showAuthStatus(msg, color) {
        const bar = document.getElementById('auth-status-bar');
        bar.classList.remove('hidden', 'bg-sky-950', 'border-sky-850', 'text-sky-400', 'bg-green-950', 'border-green-850', 'text-green-400', 'bg-rose-950', 'border-rose-850', 'text-rose-400', 'bg-amber-950', 'border-amber-850', 'text-amber-400');
        
        if (color === 'sky') bar.className = "mt-4 p-3 rounded-lg border text-center font-medium bg-sky-950 border-sky-850 text-sky-400";
        if (color === 'green') bar.className = "mt-4 p-3 rounded-lg border text-center font-medium bg-green-950 border-green-850 text-green-400";
        if (color === 'rose') bar.className = "mt-4 p-3 rounded-lg border text-center font-medium bg-rose-950 border-rose-850 text-rose-400";
        if (color === 'amber') bar.className = "mt-4 p-3 rounded-lg border text-center font-medium bg-amber-950 border-amber-850 text-amber-400";
        
        bar.textContent = msg;
        bar.classList.remove('hidden');
    }

