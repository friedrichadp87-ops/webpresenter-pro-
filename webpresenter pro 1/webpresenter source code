    function onBibleBookChange() {
        const bookSelect = document.getElementById('bible-book-select');
        const chapterSelect = document.getElementById('bible-chapter-select');
        if (!bookSelect || !chapterSelect) return;
        
        const selectedBook = bookSelect.value;
        chapterSelect.innerHTML = '<option value="">-- Pasal --</option>';
        if (!selectedBook) {
            chapterSelect.disabled = true;
            initBibleOnLoad();
            return;
        }
        const chapters = new Set();
        window.BIBLE_DATA.forEach(v => {
            if (v.book_name === selectedBook) {
                chapters.add(v.chapter);
            }
        });
        const sortedChapters = Array.from(chapters).sort((a, b) => a - b);
        sortedChapters.forEach(ch => {
            const opt = document.createElement('option');
            opt.value = ch;
            opt.textContent = `Pasal ${ch}`;
            chapterSelect.appendChild(opt);
        });
        chapterSelect.disabled = false;
        const filtered = window.BIBLE_DATA.filter(v => v.book_name === selectedBook);
        renderBibleResults(filtered.slice(0, 60));
