    function saveBibleToIndexedDB(data) {
        let request = indexedDB.open(dbName, 1);
        request.onsuccess = (e) => {
            let db = e.target.result;
            let transaction = db.transaction("store_bible", "readwrite");
            let store = transaction.objectStore("store_bible");
            store.put({ id: 1, data: data });
            transaction.oncomplete = () => {
                window.BIBLE_DATA = data;
                const statusEl = document.getElementById('bible-upload-status');
                if(statusEl) statusEl.innerHTML = `<span class="text-green-400 font-medium flex items-center gap-1"><i data-lucide="check" class="w-3.5 h-3.5"></i> Sukses Simpan: ${data.length.toLocaleString('id-ID')} Ayat</span>`;
                showToast("Database Alkitab Aktif", `${data.length.toLocaleString('id-ID')} ayat berhasil disimpan ke memori internal browser.`, "success");
                initBibleOnLoad();
                populateBibleBooksDropdown();
                searchBible();
                if (window.lucide) {
                    lucide.createIcons();
                }
            };
        };
    }

    function handleBibleUpload(event) {
        const file = event.target.files[0];
        if (!file) return;
        const statusEl = document.getElementById('bible-upload-status');
        if(statusEl) statusEl.textContent = "Membaca dan memproses file JSON...";
        
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const parsed = JSON.parse(e.target.result);
                let verses = [];
                if (Array.isArray(parsed)) verses = parsed;
                else if (parsed.verses && Array.isArray(parsed.verses)) verses = parsed.verses;
                else {
                    showToast("Gagal Membaca", "Format file JSON tidak cocok. Struktur data tidak didukung.", "error");
                    if(statusEl) statusEl.textContent = "Format tidak valid.";
                    return;
                }
                saveBibleToIndexedDB(verses);
            } catch (err) {
                showToast("Kesalahan Parsing", "Gagal menguraikan berkas JSON. Pastikan isi file valid.", "error");
                if(statusEl) statusEl.textContent = "Error parsing JSON.";
            }
        };
        reader.readAsText(file);
    }

