    function syncSongsFromCloud() {
        if (!firebaseActive) return;
        const songRef = firebase.database().ref('global_songs');
        
        songRef.on('value', (snapshot) => {
            const cloudSongs = snapshot.val();
            if (cloudSongs) {
                songBank = Object.assign({}, songBank, cloudSongs);
                localStorage.setItem('songBank', JSON.stringify(songBank));
                renderSongList();
            }
        });
    }

    function uploadSongToCloud(title, lyrics) {
        if (!firebaseActive) return;
        firebase.database().ref('global_songs/' + title).set(lyrics);
    }

    function listenToCloudLiveState() {
        if (!firebaseActive || !currentUser) return;
        
        const cleanEmailPath = currentUser.email.replace(/[^a-zA-Z0-9]/g, "_");
        const liveRef = firebase.database().ref('rooms/' + cleanEmailPath + '/live_state');
        
        liveRef.on('value', (snapshot) => {
            const data = snapshot.val();
            if (data && window.location.search.includes('view=')) {
                const viewMode = new URLSearchParams(window.location.search).get('view');
                processIncomingStateDirect(viewMode, data);
            }
        });
