  <script>
    // --- VARIABEL & STATE UTAMA ---
    const dbName = "BiblePresenterDB";
    let songBank = JSON.parse(localStorage.getItem('songBank')) || {};
    let songPlaylist = JSON.parse(localStorage.getItem('songPlaylist')) || [];
    
    let activeSlides = [];
    let activeSlideIndex = -1;
    let currentMode = ''; 
    
    let fontSizeJemaat = localStorage.getItem('fontSizeJemaat') || '7';
    let fontSizeStage = localStorage.getItem('fontSizeStage') || '12';
    let currentChurchName = localStorage.getItem('currentChurchName') || 'WEBPRESENTER';
    
    let configBg = JSON.parse(localStorage.getItem('configBg')) || { type: 'color', value: '#030712' };
    let actionStates = { clear: false, black: false, logo: false };

    let isCameraLive = false;
    let savedBg = { type: 'color', value: '#030712' };

    let myPeerId = '';
    let peer = null;
    let conn = null;
    let remoteConn = null;
    
    const localBroadcastChannel = typeof BroadcastChannel !== 'undefined' ? new BroadcastChannel('webpresenter_pro_local_sync') : null;

    // --- INTEGRASI FIREBASE & AUTHENTICATION STATE ---
    let firebaseActive = false;
    let userLoggedIn = false;
    let currentUser = null;
    let authTab = 'login';

    // Memuat konfigurasi Firebase dari LocalStorage
    let firebaseConfig = JSON.parse(localStorage.getItem('firebaseConfig')) || null;

    // --- DIALOG MODAL & TOAST CUSTOM (ANTI-ALERT) ---
    function showToast(title, message, theme = 'info') {
        const toast = document.getElementById('app-toast');
        const iconBg = document.getElementById('toast-icon-bg');
        const icon = document.getElementById('toast-icon');
        const titleEl = document.getElementById('toast-title');
        const messageEl = document.getElementById('toast-message');
        
        if(!toast || !titleEl || !messageEl) return;

        titleEl.textContent = title;
        messageEl.textContent = message;
        
        // Atur Kelas Warna Border
        toast.className = "fixed top-4 right-4 z-[200] max-w-sm bg-gray-900/95 border p-3.5 rounded-xl shadow-2xl transition-all duration-300 transform flex items-center gap-3";
        iconBg.className = "p-2 rounded-lg shrink-0";

        if (theme === 'success') {
            toast.classList.add('border-emerald-800');
            iconBg.classList.add('bg-emerald-950/60', 'text-emerald-400');
            icon.setAttribute('data-lucide', 'check-circle');
        } else if (theme === 'error') {
            toast.classList.add('border-rose-800');
            iconBg.classList.add('bg-rose-950/60', 'text-rose-400');
            icon.setAttribute('data-lucide', 'alert-circle');
        } else if (theme === 'warning') {
            toast.classList.add('border-amber-800');
            iconBg.classList.add('bg-amber-950/60', 'text-amber-400');
            icon.setAttribute('data-lucide', 'alert-triangle');
        } else {
            toast.classList.add('border-sky-800');
            iconBg.classList.add('bg-sky-950/60', 'text-sky-400');
            icon.setAttribute('data-lucide', 'info');
        }
        
        if (window.lucide) {
            lucide.createIcons();
        }
        
        toast.classList.remove('translate-x-12', 'opacity-0');
        setTimeout(() => {
            toast.classList.add('translate-x-12', 'opacity-0');
        }, 4000);
    }

    let confirmPromiseResolver = null;
    function customConfirm(title, message) {
        return new Promise((resolve) => {
            const modal = document.getElementById('confirm-modal');
            const titleEl = document.getElementById('confirm-modal-title');
            const msgEl = document.getElementById('confirm-modal-message');
            
            if(!modal || !titleEl || !msgEl) {
                resolve(false);
                return;
            }

            titleEl.textContent = title;
            msgEl.textContent = message;
            modal.classList.remove('hidden');
            confirmPromiseResolver = resolve;
        });
    }

    document.addEventListener("DOMContentLoaded", () => {
        const btnCancel = document.getElementById('confirm-modal-btn-cancel');
        const btnYes = document.getElementById('confirm-modal-btn-yes');
        const modal = document.getElementById('confirm-modal');

        if (btnCancel && btnYes) {
            btnCancel.onclick = () => {
                if (modal) modal.classList.add('hidden');
                if (confirmPromiseResolver) confirmPromiseResolver(false);
            };
            btnYes.onclick = () => {
                if (modal) modal.classList.add('hidden');
                if (confirmPromiseResolver) confirmPromiseResolver(true);
            };
        }
    });

    // --- STREAMING_CHUNK: Menyambungkan konfigurasi real-time Google Firebase SDK Client ---
    function initFirebase() {
        if (!firebaseConfig || !firebaseConfig.apiKey) {
            console.warn("Konfigurasi Google Firebase kosong. Berjalan dalam Mode Demo Lokal.");
            updateConnectionStatusIndicator(false);
            return;
        }

        try {
            if (!firebase.apps.length) {
                firebase.initializeApp(firebaseConfig);
            }
            firebaseActive = true;
            console.log("Koneksi Google Firebase Berhasil Diaktifkan!");
            updateConnectionStatusIndicator(true);

            firebase.auth().onAuthStateChanged((user) => {
                if (user) {
                    currentUser = user;
                    userLoggedIn = true;
                    document.getElementById('auth-screen').classList.add('hidden');
                    document.getElementById('active-user-name').textContent = user.email;
                    
                    syncSongsFromCloud();
                    listenToCloudLiveState();
                } else {
                    currentUser = null;
                    userLoggedIn = false;
                    document.getElementById('auth-screen').classList.remove('hidden');
                }
            });
        } catch (e) {
            console.error("Gagal menginisialisasi Firebase. Periksa kembali kunci API Anda.", e);
            showAuthStatus("Error: Kunci API Firebase Tidak Valid!", "rose");
