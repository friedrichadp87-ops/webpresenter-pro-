<!doctype html>
<html lang="id" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WebPresenter Pro</title>
  <!-- Tailwind CSS v3.4.17 untuk kerangka desain modern -->
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <!-- Lucide Icons untuk tombol & indikator visual yang premium -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <!-- SDK PeerJS & Google Firebase Legacy/Compat Libraries agar kompatibel di satu file HTML -->
  <script src="https://unpkg.com/peerjs@1.5.4/dist/peerjs.min.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>
  
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        html, body { height: 100%; margin: 0; }
        .scrollbar-thin::-webkit-scrollbar { width: 6px; }
        .scrollbar-thin::-webkit-scrollbar-thumb { background: #374151; border-radius: 3px; }
        .slide-item { transition: all 0.15s; }
        .slide-item:hover { transform: translateX(3px); }
        .monitor-frame { border: 2px solid #374151; border-radius: 8px; overflow: hidden; background: #000; position: relative; aspect-ratio: 16/9; }
        .monitor-content { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; text-align: center; padding: 1rem; color: #fff; font-weight: bold; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); }
        
        /* Gaya Teks Jarak Jauh OBS & Jemaat */
        .text-long-distance {
            text-shadow: 0 4px 12px rgba(0,0,0,0.95), 0 2px 4px rgba(0,0,0,0.95), 0 0 20px rgba(0,0,0,0.6);
            letter-spacing: 0.03em;
            line-height: 1.4;
        }
  </style>
 </head>
 <body class="h-full bg-gray-950 text-gray-100 flex flex-col overflow-hidden select-none">

  <!-- TOAST NOTIFICATION KUSTOM (PENGGANTI ALERT) -->
  <div id="app-toast" class="fixed top-4 right-4 z-[200] max-w-sm bg-gray-900/95 border border-gray-800 p-3.5 rounded-xl shadow-2xl transition-all duration-350 transform translate-x-12 opacity-0 flex items-center gap-3">
    <div id="toast-icon-bg" class="bg-sky-950/60 p-2 rounded-lg text-sky-400 shrink-0">
      <i id="toast-icon" data-lucide="info" class="w-4 h-4"></i>
    </div>
    <div class="flex-1 min-w-0">
      <div id="toast-title" class="text-[11px] font-bold text-white uppercase tracking-wider">Sistem Info</div>
      <p id="toast-message" class="text-[10px] text-gray-400 mt-0.5 leading-relaxed"></p>
    </div>
  </div>

  <!-- MODAL KONFIRMASI KUSTOM (PENGGANTI CONFIRM) -->
  <div id="confirm-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-[150] p-4 backdrop-blur-sm">
    <div class="bg-gray-900 border border-gray-800 p-6 rounded-2xl w-full max-w-sm text-center shadow-2xl">
      <div class="w-12 h-12 rounded-xl bg-amber-950/50 border border-amber-900/50 flex items-center justify-center mx-auto mb-3.5 text-amber-500">
        <i data-lucide="alert-triangle" class="w-6 h-6"></i>
      </div>
      <h3 id="confirm-modal-title" class="text-sm font-bold text-white uppercase tracking-wider mb-1.5">Konfirmasi Tindakan</h3>
      <p id="confirm-modal-message" class="text-xs text-gray-400 mb-5 leading-relaxed">Apakah Anda yakin ingin melanjutkan tindakan ini?</p>
      <div class="flex gap-2.5 justify-center text-xs">
        <button id="confirm-modal-btn-cancel" class="px-4 py-2.5 bg-gray-800 hover:bg-gray-750 border border-gray-700 text-gray-300 font-semibold rounded-lg transition">Batal</button>
        <button id="confirm-modal-btn-yes" class="px-5 py-2.5 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg transition shadow-lg shadow-rose-950/50">Lanjutkan</button>
      </div>
    </div>
  </div>

  <!-- FORM LOGIN & DAFTAR (TAMPIL DI AWAL JIKA BELUM LOGIN) -->
  <div id="auth-screen" class="fixed inset-0 bg-gray-950 z-[100] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-sky-900/20 via-gray-950 to-gray-950 pointer-events-none"></div>
    
    <div class="bg-gray-900/80 border border-gray-800 p-8 rounded-2xl w-full max-w-md shadow-2xl backdrop-blur-xl relative z-10">
      <div class="text-center mb-6">
        <div class="bg-sky-600 w-12 h-12 rounded-xl flex items-center justify-center text-white mx-auto mb-3 shadow-lg shadow-sky-950">
          <i data-lucide="monitor" class="w-6 h-6"></i>
        </div>
        <h2 class="text-xl font-bold tracking-tight text-white uppercase">WebPresenter Pro</h2>
        <p class="text-xs text-gray-400 mt-1">Sistem Kolaborasi Presentasi & Broadcast Ibadah</p>
      </div>

      <!-- Tab Buttons -->
      <div class="grid grid-cols-2 gap-2 bg-gray-950 p-1 rounded-lg border border-gray-850 mb-6 text-xs">
        <button onclick="setAuthTab('login')" id="tab-btn-login" class="py-2 rounded-md font-semibold transition text-sky-400 bg-gray-900 border border-gray-800">Masuk</button>
        <button onclick="setAuthTab('register')" id="tab-btn-register" class="py-2 rounded-md font-semibold transition text-gray-400 hover:text-white">Daftar Baru</button>
      </div>

      <form id="auth-form" onsubmit="handleAuthSubmit(event)" class="space-y-4 text-xs">
        <div>
          <label class="block text-gray-400 mb-1 font-medium">Alamat Email Gereja</label>
          <div class="relative">
            <i data-lucide="mail" class="w-4 h-4 absolute left-3 top-2.5 text-gray-500"></i>
            <input type="email" id="auth-email" required placeholder="nama@gereja.com" class="w-full bg-gray-950 border border-gray-800 hover:border-gray-700 focus:border-sky-500 rounded-lg pl-10 pr-4 py-2.5 text-white focus:outline-none transition">
          </div>
        </div>

        <div>
          <label class="block text-gray-400 mb-1 font-medium">Kata Sandi (Password)</label>
          <div class="relative">
            <i data-lucide="lock" class="w-4 h-4 absolute left-3 top-2.5 text-gray-500"></i>
            <input type="password" id="auth-password" required placeholder="••••••••" class="w-full bg-gray-950 border border-gray-800 hover:border-gray-700 focus:border-sky-500 rounded-lg pl-10 pr-4 py-2.5 text-white focus:outline-none transition">
          </div>
        </div>

        <div id="register-only-fields" class="hidden space-y-4">
          <div>
            <label class="block text-gray-400 mb-1 font-medium">Nama Organisasi / Gereja</label>
            <div class="relative">
              <i data-lucide="home" class="w-4 h-4 absolute left-3 top-2.5 text-gray-500"></i>
              <input type="text" id="auth-church" placeholder="Gereja Bethel Indonesia" class="w-full bg-gray-950 border border-gray-800 hover:border-gray-700 focus:border-sky-500 rounded-lg pl-10 pr-4 py-2.5 text-white focus:outline-none transition">
            </div>
          </div>
        </div>

        <button type="submit" id="auth-submit-btn" class="w-full bg-sky-600 hover:bg-sky-500 text-white font-semibold py-2.5 rounded-lg transition shadow-lg shadow-sky-950/50 flex items-center justify-center gap-2">
          <i data-lucide="log-in" class="w-4 h-4"></i>
          <span id="auth-btn-text">Masuk Sekarang</span>
        </button>

        <div class="relative flex py-2 items-center">
            <div class="flex-grow border-t border-gray-800"></div>
            <span class="flex-shrink mx-4 text-[10px] text-gray-500 uppercase tracking-wider font-semibold">Atau</span>
            <div class="flex-grow border-t border-gray-800"></div>
        </div>

        <button type="button" onclick="bypassAuth()" class="w-full bg-gray-800 hover:bg-gray-700 border border-gray-750 text-gray-300 font-medium py-2 rounded-lg transition flex items-center justify-center gap-1.5">
          <i data-lucide="user-check" class="w-4 h-4 text-emerald-400"></i>
          Gunakan Mode Offline (Lokal)
        </button>
      </form>

      <!-- Notifikasi Status Autentikasi -->
      <div id="auth-status-bar" class="hidden mt-4 p-3 rounded-lg border text-center font-medium animate-pulse"></div>

      <!-- Keterangan Mode -->
      <div id="auth-mode-indicator" class="mt-5 text-center text-[10px] bg-gray-950/60 p-2.5 rounded-lg border border-gray-850 text-gray-500">
        <span class="text-amber-500 font-bold">MODE LOKAL AKTIF:</span> Untuk mengaktifkan sinkronisasi database cloud antar-perangkat, silakan isi kunci konfigurasi Google Firebase di menu Sistem setelah masuk.
      </div>
    </div>
  </div>

  <!-- MAIN APP CONTAINER -->
  <header class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between shrink-0">
   <div class="flex items-center gap-3">
    <div class="bg-sky-600 p-2 rounded-lg text-white">
     <i data-lucide="monitor" class="w-5 h-5"></i>
    </div>
    <div>
     <h1 id="app-title" class="text-sm font-bold tracking-wider text-sky-400">WEBPRESENTER PRO</h1>
     <p id="app-subtitle" class="text-xs text-gray-400">Sistem Presentasi & Broadcast Ibadah</p>
    </div>
   </div>
   
   <div class="flex items-center gap-3">
    <div class="relative inline-block text-left">
     <button id="dropdown-btn" onclick="toggleDropdown()" class="flex items-center gap-2 text-xs bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-md border border-gray-700 transition font-medium text-gray-300">
      <i data-lucide="layers" class="w-4 h-4 text-sky-400"></i>
      <span>Buka Layar Output</span>
      <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-gray-500"></i>
     </button>
    <div id="dropdown-menu" class="hidden absolute right-0 mt-2 w-56 bg-gray-900 border border-gray-800 rounded-lg shadow-xl z-50 text-xs py-1">
      <button onclick="window.open('?view=jemaat', 'LayarJemaat', 'width=1024,height=576'); setTimeout(broadcastState, 300);" class="w-full text-left px-4 py-2.5 text-gray-300 hover:bg-gray-800 hover:text-white flex items-center gap-2 transition">
       <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span> Layar Utama Jemaat (TV 50")
      </button>
      <button onclick="window.open('?view=stage', 'LayarStage', 'width=1024,height=576'); setTimeout(broadcastState, 300);" class="w-full text-left px-4 py-2.5 text-gray-300 hover:bg-gray-800 hover:text-white flex items-center gap-2 transition">
       <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span> Monitor Panggung / Stage (TV 30")
      </button>
      <button onclick="window.open('?view=obs', 'LayarOBS', 'width=1920,height=1080'); setTimeout(broadcastState, 300);" class="w-full text-left px-4 py-2.5 text-rose-400 hover:bg-gray-800 hover:text-white flex items-center gap-2 transition border-t border-gray-800/60 font-medium">
       <i data-lucide="video" class="w-3.5 h-3.5"></i> Overlay OBS Streaming
      </button>
     </div>
    </div>

    <!-- Info Akun Aktif -->
    <div class="flex items-center gap-2 text-xs bg-gray-800 px-3 py-1.5 rounded-md border border-gray-700">
     <i data-lucide="user" class="w-3.5 h-3.5 text-sky-400"></i>
     <span id="active-user-name" class="text-gray-300 font-medium">Guest Mode</span>
     <button onclick="signOutUser()" class="ml-1 text-gray-500 hover:text-rose-400 transition" title="Log Out"><i data-lucide="log-out" class="w-3 h-3"></i></button>
    </div>

    <div class="flex items-center gap-2 text-xs bg-gray-800 px-3 py-1.5 rounded-md border border-gray-700">
     <span id="connection-indicator" class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
     <span id="connection-status" class="text-gray-300 font-medium">Sistem Lokal</span>
    </div>

    <div id="obs-link-container" class="hidden flex items-center gap-2 text-[11px] bg-rose-950/30 border border-rose-900/50 px-2.5 py-1.5 rounded-md text-gray-300">
     <i data-lucide="video" class="w-3.5 h-3.5 text-rose-400"></i>
     <span class="font-medium text-rose-200">OBS Link:</span>
     <input type="text" id="obs-url-input" readonly class="bg-gray-900 border border-gray-700/80 text-[10px] font-mono px-2 py-0.5 rounded text-rose-300 w-44 focus:outline-none select-all" value="">
     <button type="button" onclick="copyObsUrl()" class="bg-gray-800 hover:bg-gray-700 border border-gray-700 px-2 py-0.5 rounded text-[10px] text-gray-300 transition font-medium flex items-center gap-1">
      <i data-lucide="copy" class="w-3 h-3 text-gray-400"></i>
      <span id="obs-copy-text">Salin</span>
     </button>
    </div>
   </div>
  </header>

  <main class="flex-1 flex overflow-hidden w-full">
   
   <nav class="w-20 bg-gray-900 border-r border-gray-800 flex flex-col items-center py-4 gap-4 shrink-0">
    <button onclick="switchTab('alkitab')" id="btn-tab-alkitab" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-sky-400 bg-sky-950/50 border border-sky-800/50">
     <i data-lucide="book-open" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Alkitab</span>
    </button>
    <button onclick="switchTab('lagu')" id="btn-tab-lagu" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800">
     <i data-lucide="music" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Lagu</span>
    </button>
    <button onclick="switchTab('khotbah')" id="btn-tab-khotbah" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800">
     <i data-lucide="presentation" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Khotbah</span>
    </button>
    <button onclick="switchTab('playlist')" id="btn-tab-playlist" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800">
     <i data-lucide="list-music" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Playlist</span>
    </button>
    <button onclick="switchTab('media')" id="btn-tab-media" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800">
     <i data-lucide="image" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Media</span>
    </button>
    <button onclick="switchTab('remote')" id="btn-tab-remote" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800">
     <i data-lucide="radio" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Remote</span>
    </button>
    <button onclick="switchTab('pengaturan')" id="btn-tab-pengaturan" class="w-12 h-12 rounded-xl flex flex-col items-center justify-center gap-1 transition text-gray-400 hover:bg-gray-800 mt-auto">
     <i data-lucide="settings" class="w-5 h-5"></i>
     <span class="text-[10px] font-medium">Sistem</span>
    </button>
   </nav>

   <section class="w-80 bg-gray-900/50 border-r border-gray-800 flex flex-col overflow-hidden shrink-0">
    
    <div id="panel-alkitab" class="flex flex-col h-full p-4">
     <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3 flex items-center gap-2">
      <i data-lucide="book-open" class="w-4 h-4 text-sky-400"></i> Eksplorasi Alkitab
     </h2>
     
     <div id="bible-dropdown-container" class="grid grid-cols-2 gap-2 mb-3 hidden">
      <select id="bible-book-select" onchange="onBibleBookChange()" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-2 py-1.5 text-[11px] focus:outline-none focus:border-sky-500 text-gray-200 cursor-pointer scrollbar-thin">
       <option value="">-- Pilih Kitab --</option>
      </select>
      <select id="bible-chapter-select" onchange="onBibleChapterChange()" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-2 py-1.5 text-[11px] focus:outline-none focus:border-sky-500 text-gray-200 cursor-pointer scrollbar-thin" disabled>
       <option value="">-- Pasal --</option>
      </select>
     </div>

     <div class="flex gap-2 mb-3">
      <input type="text" id="bible-search" oninput="searchBible()" placeholder="Cari: 'Yohanes 3:16' atau kata kunci..." class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-sky-500 placeholder-gray-500">
     </div>
     <div class="flex-1 overflow-y-auto scrollbar-thin space-y-1 pr-1 text-xs" id="bible-search-results">
      <p class="text-amber-500 italic p-2 text-center bg-amber-950/20 border border-amber-900/40 rounded-lg leading-relaxed">Database kosong. Pergi ke menu 'Sistem' di kiri bawah untuk meng-upload file alkitab yang akan digunakan dengan format json terlebih dahulu.</p>
     </div>
    </div>

    <!-- PANEL BANK LAGU -->
    <div id="panel-lagu" class="flex flex-col h-full p-4 hidden">
     <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 flex items-center gap-2">
       <i data-lucide="music" class="w-4 h-4 text-emerald-400"></i> Bank Lagu
      </h2>
      <button onclick="openAddSongModal()" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded px-2 py-1 text-[11px] font-medium flex items-center gap-1 transition">
       <i data-lucide="plus" class="w-3 h-3"></i> Tambah
      </button>
     </div>
     <input type="text" id="song-search" oninput="filterSongs()" placeholder="Cari judul lagu..." class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-emerald-500 placeholder-gray-500 mb-3">
     <div class="flex-1 overflow-y-auto scrollbar-thin space-y-1 pr-1 text-xs" id="song-list-container">
      </div>
    </div>

    <!-- PANEL KHOTBAH -->
    <div id="panel-khotbah" class="flex flex-col h-full p-4 hidden">
     <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 flex items-center gap-2">
       <i data-lucide="presentation" class="w-4 h-4 text-amber-400"></i> Slide Khotbah
      </h2>
      <button onclick="clearSermonSlides()" class="text-rose-400 hover:text-rose-300 text-[11px] font-medium flex items-center gap-1 transition">
       <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Kosongkan
      </button>
     </div>
     
     <div class="bg-gray-900/40 p-3 rounded-lg border border-gray-800/80 mb-3 space-y-2 text-xs text-center">
       <label class="bg-blue-600 hover:bg-blue-500 text-white rounded px-3 py-2 text-xs font-semibold flex items-center justify-center gap-2 cursor-pointer transition shadow-md">
         <i data-lucide="upload" class="w-4 h-4"></i> Upload Gambar PPT (JPEG)
         <input type="file" id="sermon-upload-input" multiple accept="image/*" class="hidden" onchange="handleSermonUpload(event)">
       </label>
       <p class="text-[10px] text-gray-500">Urutan slide diurutkan otomatis secara numerik cerdas.</p>
     </div>

     <div class="flex justify-between items-center px-1 mb-2">
       <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Urutan Slide</span>
       <span id="sermon-counter-badge" class="bg-gray-800 text-gray-400 text-[10px] px-2 py-0.5 rounded-full border border-gray-750">0 Slide</span>
     </div>

     <div class="flex-1 overflow-y-auto scrollbar-thin space-y-2 pr-1 text-xs" id="sermon-list-container">
       <div id="sermon-empty-state" class="text-center py-8 text-gray-500 italic text-[11px] border border-dashed border-gray-800 rounded-lg p-4">
         Belum ada slide. Silakan upload gambar slide khotbah (JPEG/PNG) yang diekspor dari PPT.
       </div>
     </div>
    </div>

    <!-- PANEL PLAYLIST -->
    <div id="panel-playlist" class="flex flex-col h-full p-4 hidden">
     <div class="flex items-center justify-between mb-3">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 flex items-center gap-2">
       <i data-lucide="list-music" class="w-4 h-4 text-amber-400"></i> Playlist Ibadah
      </h2>
      <button onclick="clearPlaylist()" class="text-rose-400 hover:text-rose-300 text-[11px] font-medium flex items-center gap-1 transition">
       <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Kosongkan
      </button>
     </div>
     <div class="flex-1 overflow-y-auto scrollbar-thin space-y-1 pr-1 text-xs" id="playlist-container">
     </div>
    </div>

    <!-- PANEL MEDIA (LATAR BELAKANG TERBARU) -->
    <div id="panel-media" class="flex flex-col h-full p-4 hidden">
     <div class="flex items-center justify-between mb-3 shrink-0">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 flex items-center gap-2">
       <i data-lucide="image" class="w-4 h-4 text-purple-400"></i> Latar Belakang
      </h2>
      <button onclick="clearMediaGallery()" class="text-rose-400 hover:text-rose-300 text-[11px] font-medium flex items-center gap-1 transition">
       <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Kosongkan
      </button>
     </div>
     
     <div class="flex-1 overflow-y-auto scrollbar-thin pr-1 text-xs space-y-5">
      
      <!-- GALERI MEDIA TERSIMPAN -->
      <div>
       <div class="flex items-center justify-between mb-2">
         <label class="block text-gray-300 font-medium">Galeri Tersimpan</label>
         <label class="bg-purple-600 hover:bg-purple-500 text-white rounded px-2 py-1 text-[10px] font-semibold cursor-pointer transition flex items-center gap-1 shadow-md">
           <i data-lucide="upload" class="w-3 h-3"></i> Upload
           <input type="file" id="media-gallery-input" multiple accept="image/*,video/*" class="hidden" onchange="handleGalleryUpload(event)">
         </label>
       </div>
       <div id="media-gallery-container" class="mb-2">
         <div id="media-empty-state" class="text-center py-4 text-gray-500 italic text-[11px] border border-dashed border-gray-800 rounded-lg p-3">
           Belum ada media tersimpan. Silakan upload file Gambar/GIF/Video.
         </div>
       </div>
      </div>

      <!-- WARNA SOLID -->
      <div class="border-t border-gray-800 pt-3">
       <label class="block text-gray-400 mb-1.5 font-medium">Warna Solid Default</label>
