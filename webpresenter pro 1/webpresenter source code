    function searchBible() {
        const query = document.getElementById('bible-search').value.toLowerCase().trim();
        const container = document.getElementById('bible-search-results');
        if (!container) return;
        if (!window.BIBLE_DATA) return;
        if (!query) {
            const bookSelect = document.getElementById('bible-book-select');
            if(bookSelect && bookSelect.value) {
                onBibleChapterChange();
            } else {
                initBibleOnLoad();
            }
            return;
        }
        
        const match = query.match(/^([1-3]?\s?[a-zA-Z]+)\s+([0-9]+)(?::([0-9]+))?$/);
        if (match) {
            const bName = match[1].replace(/\s+/g, '').toLowerCase();
            const chap = parseInt(match[2]);
            const ver = match[3] ? parseInt(match[3]) : null;
            
            const filtered = window.BIBLE_DATA.filter(v => {
                const targetBName = v.book_name.replace(/\s+/g, '').toLowerCase();
                if (targetBName !== bName && !targetBName.startsWith(bName)) return false;
                if (v.chapter !== chap) return false;
                if (ver !== null && v.verse !== ver) return false;
                return true;
            });
            if (filtered.length > 0) {
                renderBibleResults(filtered);
                return;
            }
        }
        
        const filtered = window.BIBLE_DATA.filter(v => 
            v.text.toLowerCase().includes(query) || 
            v.book_name.toLowerCase().includes(query)
        );
        renderBibleResults(filtered.slice(0, 50));
    }

    function renderBibleResults(verses) {
        const container = document.getElementById('bible-search-results');
