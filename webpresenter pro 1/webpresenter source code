                if(a === 'clear') btn.className = "bg-amber-600 text-white border border-amber-500 rounded-xl py-3 flex flex-col items-center justify-center gap-1 transition shadow-lg shadow-amber-950";
                if(a === 'black') btn.className = "bg-rose-700 text-white border border-rose-600 rounded-xl py-3 flex flex-col items-center justify-center gap-1 transition shadow-lg shadow-rose-950";
