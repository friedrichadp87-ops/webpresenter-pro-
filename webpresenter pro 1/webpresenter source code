        verses.forEach(v => {
            const ref = `${v.book_name} ${v.chapter}:${v.verse}`;
            const item = document.createElement('div');
            item.className = "p-2 bg-gray-800/40 hover:bg-sky-950/30 border border-gray-800 hover:border-sky-800 rounded-lg cursor-pointer transition text-left";
            item.innerHTML = `<div class="font-bold text-sky-400 text-[11px] mb-0.5">${ref}</div><div class="text-gray-300 leading-normal text-[11px] font-medium">${v.text}</div>`;
            item.onclick = () => {
                loadVerseToQueue({ kitab: v.book_name, pasal: v.chapter, referensi: ref, teks: v.text });
            };
            container.appendChild(item);
        });
    }

